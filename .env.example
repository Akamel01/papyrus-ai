# SME Research Assistant — Environment Template
# Copy to .env and fill in your values:  cp .env.example .env
# Updated for multi-user mode on 2026-03-18

# ── Multi-User Authentication ──
# Generate secrets with: openssl rand -base64 32
JWT_SECRET=                    # Required: JWT signing key (32+ chars)
MASTER_ENCRYPTION_KEY=         # Required: API key encryption (32 bytes base64)
ADMIN_EMAIL=                   # Optional: Initial admin account email
ADMIN_PASSWORD=                # Optional: Initial admin account password (min 12 chars)

# ── Legacy Auth (Dashboard) ──
ADMIN_USERNAME=      # your dashboard admin username
STREAMLIT_PASSWORD=  # password for Streamlit UI access (will be replaced by multi-user auth)

# ── API Keys ──
OPENALEX_API_KEY=    # https://openalex.org/
SEMANTIC_SCHOLAR_API_KEY=  # https://www.semanticscholar.org/product/api
SME_EMAILS=          # your email address for API identification

# ── Service URLs (internal Docker network) ──
QDRANT_URL=http://sme_qdrant:6333
OLLAMA_URL=http://sme_ollama:11434

# ── Auto-Deploy Webhook ──
# Generate with: openssl rand -hex 32
DEPLOY_WEBHOOK_SECRET=         # GitHub webhook secret for auto-deploy

# ── Ollama ──
# Link your account after first start:
#   docker exec -it sme_ollama ollama signin
