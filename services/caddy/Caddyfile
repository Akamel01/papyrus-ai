# SME Research Assistant - Caddy Reverse Proxy Configuration
# Routes traffic to appropriate backend services

:80 {
    # ─── Security Headers ───
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' wss: ws:;"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }
    # ─── Auth API ───
    # Health endpoint (maps /api/auth/health to /health)
    handle /api/auth/health {
        rewrite * /health
        reverse_proxy auth:8000
    }

    # Other auth endpoints (pass through as-is)
    handle /api/auth/* {
        reverse_proxy auth:8000
    }

    # ─── Chat UI (Streamlit) ───
    # Streamlit requires WebSocket support
    handle /chat* {
        reverse_proxy app:8501 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ─── Streamlit static assets under /chat ───
    handle /chat/static/* {
        reverse_proxy app:8501
    }

    handle /chat/_stcore/* {
        reverse_proxy app:8501
    }

    # ─── Streamlit static assets ───
    handle /_stcore/* {
        reverse_proxy app:8501
    }
    handle /static/* {
        reverse_proxy app:8501
    }
    handle /healthz {
        reverse_proxy app:8501
    }

    # ─── Dashboard UI ───
    handle /dashboard* {
        reverse_proxy dashboard-ui:3000
    }

    # ─── Dashboard API ───
    handle /api/* {
        reverse_proxy dashboard-backend:8400
    }

    # ─── Default: Redirect to Chat ───
    handle {
        redir /chat permanent
    }

    # ─── Logging ───
    log {
        output stdout
        format console
        level INFO
    }
}
